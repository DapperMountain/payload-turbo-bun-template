{
  "name": "@dappermountain/payload-turbo-bun-template",
  "description": "Payload CMS Monorepo using Turborepo and Bun",
  "private": true,
  "scripts": {
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "skills:update": "bunx skills update payload -y -p",
    "skills:check": "bunx skills check -p",
    "skills:install": "bunx skills add payloadcms/skills --skill payload -y --copy -a '*'",
    "hooks:install": "git-hooks",
    "hooks:uninstall": "git-hooks uninstall"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "~10.4.22",
    "bun-git-hooks": "^0.3.2",
    "cross-env": "7.0.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "next": "16.2.4",
    "prettier": "~3.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "~6.0.1",
    "turbo": "canary",
    "typescript": "5.9.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.13"
}
