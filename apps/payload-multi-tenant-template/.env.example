PAYLOAD_SECRET="YOUR_SECRET_HERE"

DATABASE_HOST=db
DATABASE_HOST_TEST=db-test
DATABASE_NAME=payload
DATABASE_USER=payload
DATABASE_PASSWORD=payload
DATABASE_URL=postgres://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}/${DATABASE_NAME}

# Optional: dedicated DB for `bun test` on the host (NODE_ENV=test). Compose `db-test` publishes 5432 → host 5443.
# Not `db-test` — that hostname only works inside the compose network. Falls back to DATABASE_URL if unset.
# DATABASE_URL_TEST=postgres://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST_TEST}/${DATABASE_NAME}
DATABASE_URL_TEST=postgres://${DATABASE_USER}:${DATABASE_PASSWORD}@localhost:5443/${DATABASE_NAME}

# Optional: disable | prefer | require (default: disable)
# DATABASE_SSL=disable
# DATABASE_POOL_MAX=10
# Set false for self-signed certs when DATABASE_SSL=require
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

DATA_SEED_ENABLED=1
DATA_SEED_ADMIN_EMAIL=admin@example.com
DATA_SEED_ADMIN_FIRST_NAME=SYSTEM
DATA_SEED_ADMIN_LAST_NAME=ADMIN
DATA_SEED_ADMIN_PASSWORD=admin
DATA_SEED_USER_EMAIL=user@example.com
DATA_SEED_USER_FIRST_NAME=SYSTEM
DATA_SEED_USER_LAST_NAME=USER
DATA_SEED_USER_PASSWORD=user

# Public URL (browser + CORS). Must match how users reach the app.
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Optional: internal/server URL (Docker service name, Fly internal). Defaults to NEXT_PUBLIC_SERVER_URL.
# SERVER_URL=http://payload-multi-tenant-template:3000

# Optional: extra CORS origins (comma-separated). Public URL is always included.
# CORS_ORIGINS=http://localhost:3000,https://preview.example.com

# Optional: trust X-Forwarded-* behind reverse proxy (default: true in production)
# TRUST_PROXY=true

# Optional feature flags (defaults shown)
# PAYLOAD_TELEMETRY_ENABLED=false
# GRAPHQL_ENABLED=true
# MCP_ENABLED=true

NEXT_TELEMETRY_DISABLED=1
