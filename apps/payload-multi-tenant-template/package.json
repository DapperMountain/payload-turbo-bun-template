{
  "name": "@dappermountain/payload-multi-tenant-template",
  "version": "1.0.0",
  "description": "Payload CMS Multi-Tenant Template using Turborepo and Bun",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "next dev",
    "payload": "payload",
    "generate:importmap": "payload generate:importmap",
    "generate:schema": "payload-graphql generate:schema",
    "generate:types": "payload generate:types",
    "db:migrate:run": "payload migrate",
    "db:migrate:create": "payload migrate:create",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "start": "next start",
    "test": "bun test",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@dappermountain/design-system": "workspace:*",
    "cross-env": "7.0.3",
    "dotenv": "16.4.7",
    "drizzle-kit": "^0.31.9",
    "zod": "4.0.17"
  },
  "devDependencies": {
    "babel-plugin-react-compiler": "~19.1.0-rc.3",
    "jsdom": "28.0.0"
  }
}
