{
  "name": "@dappermountain/payload-multi-tenant-template",
  "version": "1.0.0",
  "description": "Payload CMS Multi-Tenant Template using Turborepo and Bun",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "prebuild": "cd ../../packages/design-system && bun run generate:css",
    "dev": "next dev",
    "payload": "payload",
    "generate:importmap": "payload generate:importmap",
    "generate:schema": "payload-graphql generate:schema",
    "generate:types": "payload generate:types",
    "db:migrate:run": "payload migrate",
    "db:migrate:create": "payload migrate:create",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "start": "next start",
    "test": "bun test"
  },
  "dependencies": {
    "@dappermountain/design-system": "workspace:*",
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-multi-tenant": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/translations": "^3.84.1",
    "@payloadcms/ui": "3.84.1",
    "cross-env": "7.0.3",
    "drizzle-kit": "^0.31.10",
    "graphql": "16.8.1",
    "payload": "3.84.1",
    "react-native": "^0.85.3",
    "react-native-web": "^0.21.2",
    "server-only": "^0.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@payloadcms/graphql": "3.84.1",
    "babel-plugin-react-compiler": "~19.1.0-rc.3",
    "jsdom": "28.0.0"
  }
}
