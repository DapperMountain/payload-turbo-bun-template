# Test environment — copy to `.env.test` for local runs (`bun test` from the app directory).
#
# CI / Docker / production-like deploys: inject these keys via the platform environment
# instead of committing a file. Shell and platform env always win over file values.
#
# Dev DB (port 5442) and test DB (port 5443) are separate Postgres containers in root `compose.yml`.

NODE_ENV=test

# Dev / app (Docker `db` service → host 5442)
DATABASE_URL=postgres://payload:payload@localhost:5442/payload

# Integration tests (`NODE_ENV=test` → `config.database.uri` uses this when set)
DATABASE_URL_TEST=postgres://payload:payload@localhost:5443/payload

NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_SECRET=test-secret-do-not-use-in-production-32c

# Off for tests (suite truncates in afterAll; tests create their own rows)
DATA_SEED_ENABLED=0

# Optional: disable MCP during tests (default in dev/prod is enabled)
# MCP_ENABLED=false
